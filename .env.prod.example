# ===========================================
# BFF Service - Production Environment
# ===========================================

# Docker Registry
DOCKER_REGISTRY=your-registry.com/
IMAGE_TAG=latest

# Application
STAGE=PROD
APP_NAME=BFF-SERVICE
APP_PORT=3000

# Redis (use your Redis cluster URL)
REDIS_HOST=redis://redis-cluster:6379

# Auth (use strong secret in production!)
BFF_JWT_SECRET=your-production-jwt-secret-min-32-chars

# Backend Services (internal service URLs)
USERS_SERVICE_URL=http://users-service:3001
ORDERS_SERVICE_URL=http://orders-service:3002
PRODUCTS_SERVICE_URL=http://products-service:3003
NOTIFICATIONS_SERVICE_URL=http://notifications-service:3004

# Cache
BFF_CACHE_ENABLED=true
BFF_CACHE_DEFAULT_TTL=300

# Deployment
REPLICAS=2
CPU_LIMIT=1
MEMORY_LIMIT=512M
CPU_RESERVATION=0.25
MEMORY_RESERVATION=256M

# Networking
BFF_DOMAIN=bff.your-domain.com
BACKEND_NETWORK=globalsone-backend
