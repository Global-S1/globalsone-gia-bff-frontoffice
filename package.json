{
  "name": "globalsone-bff-template",
  "version": "1.0.0",
  "description": "BFF (Backend for Frontend) template for GlobalS1 microservices architecture - aggregates data from multiple services",
  "main": "build/index.js",
  "scripts": {
    "dev": "nodemon index.ts",
    "start": "node build/index.js",
    "build": "tsc",
    "test": "jest --verbose --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "bff",
    "backend-for-frontend",
    "microservices",
    "aggregation",
    "express",
    "typescript",
    "docker"
  ],
  "author": "GlobalS1",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "redis": "^4.7.1",
    "undici": "^6.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.7.2",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.1",
    "pino-pretty": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
