{
  "services": {
    "ms-auth": {
      "name": "ms-auth-gia",
      "baseUrl": "${MS_AUTH_URL}",
      "timeout": 5000,
      "retries": 2,
      "healthPath": "/v1/health"
    },
    "ms-agents": {
      "name": "ms-agents-gia",
      "baseUrl": "${MS_AGENTS_URL}",
      "timeout": 10000,
      "retries": 1,
      "healthPath": "/v1/health/live"
    },
    "ms-documents": {
      "name": "ms-documents-gia",
      "baseUrl": "${MS_DOCUMENTS_URL}",
      "timeout": 15000,
      "retries": 1,
      "healthPath": "/health"
    }
  }
}
